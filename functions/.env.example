# Copy this file to .env and fill in your values.
# .env is gitignored and must NEVER be committed.
#
# TEST-PHASE: plain env vars (no Secret Manager) — see functions/src/config/env.ts.
# Production: move keys to Secret Manager once deployer has setIamPolicy access.

GEMINI_API_KEY=your_gemini_api_key_here

# Model selection — change this line to switch between free and paid models.
# No code change needed; just restart the emulator after editing.
#
# Stable production default (2026): gemini-3.5-flash
#
GEMINI_MODEL=gemini-3.5-flash

# Optional: retry this model once when GEMINI_MODEL hits quota limits.
# Leave empty to disable fallback retry.
# GEMINI_FALLBACK_MODEL=gemini-flash-latest

# Optional: disable Gemini Google Search grounding for Opportunity Finder.
# Set false when the search/tool quota is exhausted.
OPPORTUNITY_USE_GOOGLE_SEARCH=true

# KAIRLLM — OpenAI-compatible multi-model gateway ("auto" model). Selectable
# provider for paid+ users; free users stay on Gemini. Key stays server-side.
KAIRLLM_API_KEY=your_kairllm_api_key_here
KAIRLLM_BASE_URL=https://ai.gogosling.ca/v1

# DeepSeek — paid-tier provider. Our API key; NOT the user's key.
# Base URL defaults to https://api.deepseek.com/v1 if unset.
DEEPSEEK_API_KEY=your_deepseek_api_key_here
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# Future provider keys (just add a row to functions/src/llm/models.ts to expose):
# QWEN_API_KEY=
# OPENAI_API_KEY=

# Stripe billing
# Local emulator only: copy real test values into functions/.env (gitignored).
# Deployed functions: prefer Secret Manager:
#   firebase functions:secrets:set STRIPE_SECRET_KEY
#   firebase functions:secrets:set STRIPE_WEBHOOK_SECRET
#
# Never expose the secret key in frontend code. The browser calls
# createCheckoutSession; Stripe Checkout URLs are created server-side.
APP_BASE_URL=http://127.0.0.1:4173
BILLING_SIMULATION=false
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me

# Stripe Price IDs, not Payment Links. Create these in Stripe Dashboard:
# Product catalog -> Product -> Prices. Each should start with "price_".
STRIPE_PRICE_ESSENTIALS=price_replace_me
STRIPE_PRICE_ACCELERATOR=price_replace_me
STRIPE_PRICE_EXECUTIVE=price_replace_me
STRIPE_PRICE_STARTER=price_replace_me
STRIPE_PRICE_GROWTH=price_replace_me
STRIPE_PRICE_PRO=price_replace_me
STRIPE_PRICE_PACK_100=price_replace_me
STRIPE_PRICE_PACK_500=price_replace_me
STRIPE_PRICE_PACK_1000=price_replace_me

# Do not configure or sell the legacy SINGLE_POST / JOB_PACK products. New
# checkout is server-blocked until consumable posting credits and expiry exist.
