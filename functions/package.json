{
  "name": "career-copilot-functions",
  "description": "Firebase Cloud Functions for Career CoPilot — server-side AI proxy, credit logic, and Stripe backend.",
  "engines": {
    "node": "22"
  },
  "main": "lib/index.js",
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "serve": "npm run build && firebase emulators:start --only functions,auth --project demo-careercopilot",
    "dev": "firebase emulators:start --only functions,auth --project demo-careercopilot",
    "lint": "eslint --ext .ts src/",
    "audit:business-roles": "node scripts/auditBusinessRoleProvenance.js"
  },
  "dependencies": {
    "@google/genai": "^1.52.0",
    "@sentry/node": "^10.59.0",
    "firebase-admin": "^12.0.0",
    "firebase-functions": "^7.2.5",
    "stripe": "^22.3.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "firebase-functions-test": "^3.0.0",
    "typescript": "^5.0.0"
  }
}
