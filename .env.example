# .env.example
# Please copy this file and rename it to .env.local, then fill in your Firebase Web App config.
#
# NOTE: There is NO Gemini key in the browser anymore. All AI runs server-side via
# Cloud Functions — the Gemini key + model selection live in functions/.env
# (GEMINI_API_KEY / GEMINI_MODEL) and Firebase Secret Manager. See functions/.env.example.

# Firebase Web App config.
VITE_FIREBASE_API_KEY=your_firebase_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
VITE_FIREBASE_APP_ID=your_firebase_app_id
VITE_FIREBASE_FUNCTIONS_REGION=us-central1

# Stripe browser key. Use pk_test_* for sandbox builds. Never put sk_* keys here.
# When omitted, the app falls back to hosted Checkout redirects.
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key_here
