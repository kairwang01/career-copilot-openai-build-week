# Firestore "Trigger Email" extension — config as code.
#
# WHY: functions/src/handlers/notifications.ts enqueues candidate interview-progress
# emails into the `mail` collection. That collection is ONLY drained by the Firebase
# "Trigger Email from Firestore" extension — which is currently NOT installed on the
# project (verified: `firebase ext:list` → "no extensions installed"). Until it is
# installed, the in-app bell notification works but NO email is ever delivered.
#
# INSTALL (one-time, needs your SMTP provider + credentials — e.g. SendGrid, Resend,
# Mailgun, AWS SES, or Gmail SMTP):
#   1. cp extensions/firestore-send-email.env.example extensions/firestore-send-email.env
#   2. Fill SMTP_CONNECTION_URI below (put the password in Secret Manager, not plaintext).
#   3. firebase ext:install firebase/firestore-send-email --project career-copilot-a3168
#      (or `firebase deploy --only extensions` once firebase.json has the extensions block)
#   4. Send a status change in the Applicant Funnel and confirm the candidate gets the email.
#
# The MAIL_COLLECTION below MUST stay "mail" — it must match notifications.ts:117.

# Collection the extension watches. Do not change — the producer writes to `mail`.
MAIL_COLLECTION=mail

# SMTP connection string. Store the password as a Secret Manager secret and reference it,
# e.g. smtps://apikey@smtp.example.com:465  with the secret supplied at install time.
# Example (SendGrid): smtps://apikey:SENDGRID_API_KEY@smtp.sendgrid.net:465
SMTP_CONNECTION_URI=

# The From: address shown to candidates.
DEFAULT_FROM=Career CoPilot <no-reply@your-domain.com>

# Optional reply-to.
# DEFAULT_REPLY_TO=support@your-domain.com

# Location must match the functions region.
LOCATION=us-central1

# Optional: expire delivered mail docs (days) to keep the collection from growing.
# TTL_EXPIRE_TYPE=day
# TTL_EXPIRE_VALUE=30
